{
  "name": "papaya-fleet",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.7.2",
      "better-auth": "1.5.2",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@prisma/client": "^7.2.0",
      "@trpc/client": "^11.7.2",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "ci": "./scripts/ci-checks.sh",
    "ci:all": "./scripts/ci-checks.sh --e2e",
    "check": "./scripts/ci-checks.sh",
    "check:all": "./scripts/ci-checks.sh --e2e",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @papaya-fleet/db db:push",
    "db:studio": "turbo -F @papaya-fleet/db db:studio",
    "db:generate": "turbo -F @papaya-fleet/db db:generate",
    "db:migrate": "turbo -F @papaya-fleet/db db:migrate",
    "db:start": "turbo -F @papaya-fleet/db db:start",
    "db:watch": "turbo -F @papaya-fleet/db db:watch",
    "db:stop": "turbo -F @papaya-fleet/db db:stop",
    "db:down": "turbo -F @papaya-fleet/db db:down",
    "db:seed": "turbo -F @papaya-fleet/db db:seed",
    "docker:up": "./scripts/docker-dev.sh up",
    "docker:down": "./scripts/docker-dev.sh down",
    "docker:logs": "./scripts/docker-dev.sh logs",
    "docker:reset": "./scripts/docker-dev.sh reset",
    "docker:init": "./scripts/docker-init.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@papaya-fleet/env": "workspace:*",
    "dotenv": "catalog:",
    "react-hook-form": "^7.72.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@papaya-fleet/config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "catalog:",
    "@vitest/ui": "^4.1.0",
    "happy-dom": "^20.8.4",
    "turbo": "^2.8.12",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "packageManager": "bun@1.2.23"
}
